variable "services"        { type = string }
variable "downloads_dir"  { type = string }
variable "tld"            { type = string }

job "transmission" {
  type = "service"

  group "transmission" {

    network {
      port "http" { static = 9091 }
    }

    service {
      name = "transmission"        
      port = "http"
      tags = [
        "traefik.enable=true",
        "traefik.http.routers.transmission.rule=Host(`transmission.${var.tld}`)",
        "traefik.http.routers.transmission.entrypoints=websecure",					
        "traefik.http.routers.transmission.middlewares=auth"
      ]    
      check {
        type     = "tcp"
        interval = "60s"
        timeout  = "20s"
      }
    }	

    task "transmission" {
      driver = "docker"
			
      config {
        image = "linuxserver/transmission"
        network_mode = "host"
        ports = ["http"]
        volumes = [
          "${var.services}/transmission:/config",
          "${var.downloads_dir}:/downloads",
          "${var.downloads_dir}/incomplete:/incomplete",
          "${var.services}/transmission/torrents:/data/watch",
        ]
      }

      template {
        env = true
        destination = "local/env"
        data = file("transmission/.env")          
      }               

      resources {
        cpu    = 500
        memory = 512
      }   
    }
  }
}